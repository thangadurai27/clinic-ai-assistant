# KLM AI Clinic Assistant — Backend Environment Variables Example

# App
APP_NAME="KLM AI Clinic Assistant"
APP_VERSION="1.0.0"
DEBUG=False
SECRET_KEY="replace-with-a-random-secret-key-for-production"

# Groq LLM
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"

# Supabase
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-role-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your-token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Google OAuth2 (Gmail API)
# Use OAuth 2.0 Playground or other tools to get the refresh token
GOOGLE_CLIENT_ID="...apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."
GOOGLE_REFRESH_TOKEN="1//0..."

# Clinic Information
CLINIC_NAME="KLM AI Clinic"
CLINIC_ADDRESS="123 Health Street, Medical District, NY 10001"
CLINIC_PHONE="+911234567890"
CLINIC_EMAIL="your-clinic@gmail.com"
CLINIC_HOURS="Monday-Friday: 8AM-6PM, Saturday: 9AM-2PM"

# Inbox Polling
IMAP_SERVER="imap.gmail.com"
IMAP_PORT=993
IMAP_EMAIL="your-clinic@gmail.com"
IMAP_PASSWORD="your-google-app-password"

# Safety
CONFIDENCE_THRESHOLD=0.6
